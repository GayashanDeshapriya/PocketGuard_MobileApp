<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activities.Login"
    android:padding="20dp"
    android:layout_marginTop="0dp">


    <RelativeLayout
        android:layout_width="384dp"
        android:layout_height="130dp"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/LogoImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="left"
            android:contentDescription="@string/profile_picture_description"
            android:src="@drawable/icons_and_logo" />

        <TextView
            android:id="@+id/LogoName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toRightOf="@+id/LogoImage"
            android:text="Expenses"
            android:textColor="@color/black"
            android:textSize="40sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        android:padding="0dp"
        android:layout_gravity="center">



        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Expense Name"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="30dp"/>

        <TextView
            android:id="@+id/tvExpenseName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text=""
            android:gravity="center"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/blue_800"/>

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Expense Amount"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="30dp"/>

        <TextView
            android:id="@+id/tvExpenseAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text=""
            android:gravity="center"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/blue_800"/>

        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Expense Category"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="30dp"/>

        <TextView
            android:id="@+id/tvExpenseCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text=""
            android:gravity="center"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/blue_800"/>


        <TextView
            android:id="@+id/textView4"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Expense Description"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="30dp"/>

        <TextView
            android:id="@+id/tvExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text=""
            android:gravity="center"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/blue_800"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            >

            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/button_bg"
                android:text="UPDATE"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_marginLeft="220dp"
                android:background="@drawable/button_bg"
                android:text="DELETE"
                android:textColor="@color/white"
                />

        </RelativeLayout>

    </LinearLayout>

    <Button
        android:id="@+id/back1"
        android:layout_width="175dp"
        android:layout_height="50dp"
        android:layout_marginLeft="100dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/button_bg"
        android:text="Back"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_default="wrap" />


</LinearLayout>